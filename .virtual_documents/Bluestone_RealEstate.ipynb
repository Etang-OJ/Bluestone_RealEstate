drop_leakage = [
    "FINAL_SALE_PRICE",
    "LOG_FINAL_SALE_PRICE"
]

df_model = sales_df.drop(columns=drop_leakage)


# Select only numeric / boolean columns for correlation

corr_candidates = df_model.select_dtypes(include=[np.number, "bool"]).copy()

corr_matrix = corr_candidates.corr().abs()


df_model.info()


threshold = 0.85

upper_triangle = corr_matrix.where(
    np.triu(np.ones(corr_matrix.shape), k=1).astype(bool)
)

to_drop = [
    col for col in upper_triangle.columns
    if any(upper_triangle[col] > threshold)
]

print("Initially flagged for dropping:")
print(to_drop)


protected = {
    "LIST_PRICE",
    "MARKET_AVG_PRICE",
    "OFFER_TO_LIST_RATIO",
    "MARKET_PRESSURE_CAPPED",
    "NEGOTIATION_GAP_CAPPED",
    "ZIP_ACTIVITY",
    "SALE_MONTH",
    "SALE_QUARTER"
}

to_drop_final = [col for col in to_drop if col not in protected]

print("Final columns to drop:")
print(to_drop_final)



